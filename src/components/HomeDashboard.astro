---
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "../config";
import { resolveImageSrc } from "../utils/image-utils";
import { getPostUrlBySlug, getTagUrl, url } from "../utils/url-utils";
import Navbar from "./Navbar.astro";

interface Props {
	posts: CollectionEntry<"posts">[];
	anime: CollectionEntry<"anime">[];
	novels: CollectionEntry<"novels">[];
}

type FavoriteEntry = CollectionEntry<"anime"> | CollectionEntry<"novels">;

const { posts, anime, novels } = Astro.props;
const publishedPosts = posts.filter((post) => !post.data.draft);
const recentPosts = publishedPosts.slice(0, 5);
const tags = Array.from(
	publishedPosts
		.flatMap((post) => post.data.tags)
		.reduce(
			(map, tag) => map.set(tag, (map.get(tag) || 0) + 1),
			new Map<string, number>(),
		),
)
	.sort((a, b) => b[1] - a[1])
	.slice(0, 10);

const formatDate = (date: Date) =>
	new Intl.DateTimeFormat("zh-CN", {
		month: "2-digit",
		day: "2-digit",
	}).format(date);

const favoriteImages = import.meta.glob<{ default: { src: string } }>(
	"../assets/images/favorites/**/*.{avif,gif,jpeg,jpg,png,webp}",
	{ eager: true },
);

const sortFavorites = <T extends FavoriteEntry>(items: T[]) =>
	[...items].sort((a, b) => {
		if (a.data.featured !== b.data.featured) {
			return a.data.featured ? -1 : 1;
		}
		return b.data.rating - a.data.rating;
	});

const favoritePreview = sortFavorites(anime).slice(0, 4);

const normalizeStatus = (status: string) => {
	if (status === "追更中") return "在看";
	if (status === "已看完") return "看过";
	return status || "想看";
};
---

<Navbar />

<main class="home-page relative overflow-x-hidden" data-pagefind-body>
	<section class="hero relative z-10" aria-label="个人主页概览">
		<figure class="hero-stage">
			<img src={siteConfig.banner.src} alt="Homepage wallpaper" class="hero-image" />
			<div class="hero-scrim"></div>
			<div class="hero-copy">
				<p class="eyebrow">Personal Homepage</p>
				<h1 class="font-display tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white via-[oklch(0.92_0.06_var(--hue-20))] to-[oklch(0.85_0.1_var(--hue-120))]">{profileConfig.name}</h1>
				<p class="intro">{profileConfig.bio}</p>
				<div class="hero-pills" aria-label="兴趣标签">
					<span>小说</span>
					<span>国漫</span>
					<span>研究</span>
					<span>钻研</span>
				</div>
				<div class="hero-actions">
					<a class="primary-action group" href={url("/archive/")}>
						<span>阅读文章</span>
						<Icon name="material-symbols:arrow-forward-rounded" class="transition-transform group-hover:translate-x-1" />
					</a>
					<a class="secondary-action" href={url("/about/")}>关于我</a>
				</div>
			</div>
		</figure>
	</section>

	<section class="content-grid relative z-10" aria-label="首页内容">
		<section class="surface recent-section">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Recent Posts</p>
					<h2>最近更新</h2>
				</div>
				<a href={url("/archive/")}>全部文章</a>
			</div>

			<div class="post-list">
				{recentPosts.map((post) => (
					<a href={getPostUrlBySlug(post.slug)} class="post-row">
						<span class="post-date">{formatDate(post.data.published)}</span>
						<div>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
						</div>
						<Icon name="material-symbols:chevron-right-rounded" />
					</a>
				))}
			</div>
		</section>

		<aside class="side-stack">
			<section class="surface links-section">
				<p class="eyebrow">Links</p>
				<div class="link-list">
					{profileConfig.links.map((link) => (
						<a href={link.url} target="_blank" rel="noopener noreferrer">
							<Icon name={link.icon} />
							<span>{link.name}</span>
						</a>
					))}
				</div>
			</section>

			<section class="surface tags-section">
				<p class="eyebrow">Tags</p>
				<div class="tag-cloud">
					{tags.map(([tag]) => (
						<a href={getTagUrl(tag)}>{tag}</a>
					))}
				</div>
			</section>
		</aside>
	</section>

	{favoritePreview.length > 0 && (
		<section class="favorite-preview relative z-10" aria-label="动漫收藏预览">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Anime Collection</p>
					<h2>动漫收藏</h2>
				</div>
				<a href={url("/anime/")}>全部 {anime.length} 部</a>
			</div>

			<div class="favorite-grid">
				{favoritePreview.map((item) => {
					const imageSrc = resolveImageSrc(item.data.image, favoriteImages);
					const status = normalizeStatus(item.data.status);
					return (
						<a href={url("/anime/")} class="favorite-card">
							<div class="favorite-poster">
								{imageSrc ? (
									<img src={imageSrc} alt={item.data.title} loading="lazy" />
								) : (
									<div class="favorite-placeholder">
										<Icon name="material-symbols:movie-outline-rounded" />
									</div>
								)}
								<span>{status}</span>
							</div>
							<div class="favorite-body">
								<h3>{item.data.title}</h3>
								<p>{item.data.description || item.data.progress || "慢慢补完这部作品的记录。"}</p>
								<div class="favorite-meta">
									{item.data.rating > 0 && (
										<span>
											<Icon name="material-symbols:star-rounded" />
											{item.data.rating}
										</span>
									)}
									{item.data.creator && <span>{item.data.creator}</span>}
								</div>
							</div>
						</a>
					);
				})}
			</div>
		</section>
	)}

	<section class="quick-grid relative z-10" aria-label="内容入口">
		<a href={url("/novels/")}>
			<Icon name="material-symbols:menu-book-outline-rounded" />
			<strong>小说收藏</strong>
			<span>{novels.length} 本收藏、追更和作品结构记录</span>
		</a>
		<a href={url("/anime/")}>
			<Icon name="material-symbols:movie-outline-rounded" />
			<strong>动漫收藏</strong>
			<span>{anime.length} 部国漫、动画和喜欢的作品</span>
		</a>
		<a href={url("/diary/")}>
			<Icon name="material-symbols:edit-note-rounded" />
			<strong>日记</strong>
			<span>生活观察和阶段性想法</span>
		</a>
		<a href={url("/album/")}>
			<Icon name="material-symbols:photo-library-outline-rounded" />
			<strong>相册</strong>
			<span>值得留下来的画面</span>
		</a>
	</section>
</main>

<style>
	.home-page {
		min-height: 100vh;
		padding: 0 1.25rem 4rem;
		background: transparent;
		color: var(--color-text);
		transition: color 0.25s ease;
	}

	.hero,
	.content-grid,
	.favorite-preview,
	.quick-grid {
		width: min(100%, 76rem);
		margin: 0 auto;
	}

	.hero {
		padding: 1.5rem 0 clamp(2rem, 5vw, 4rem);
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.hero h1 {
		max-width: 13ch;
		margin: 0;
		font-size: clamp(3rem, 8vw, 6.8rem);
		font-weight: 850;
		letter-spacing: 0;
		line-height: 0.96;
	}

	.intro {
		max-width: 38rem;
		margin: 1.5rem 0 0;
		color: var(--color-muted);
		font-size: 1.08rem;
		line-height: 1.8;
	}

	:global(.dark) .intro,
	:global(.dark) .post-row p {
		color: var(--color-muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.primary-action,
	.secondary-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.1rem;
		border-radius: 8px;
		padding: 0 1.25rem;
		font-weight: 800;
		color: white;

		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.primary-action {
		gap: 0.4rem;
		background: var(--primary);
		box-shadow: 0 8px 24px var(--color-glow);
		border: none;
	}

	.primary-action:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 32px oklch(0.58 0.2 var(--hue) / 0.5);
	}

	.secondary-action {
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
	}

	.secondary-action:hover {
		border-color: rgba(255, 255, 255, 0.3);
		background: rgba(255, 255, 255, 0.15);
		transform: translateY(-2px);
	}

	.surface {
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-surface);
		backdrop-filter: blur(16px);
		color: var(--color-text);
		padding: 1.25rem;
		box-shadow: 
			0 12px 32px -4px rgba(0, 0, 0, 0.02),
			0 4px 12px -2px rgba(0, 0, 0, 0.01),
			inset 0 1px 1px rgba(255, 255, 255, 0.35);
		transition:
			background-color 0.25s ease,
			border-color 0.25s ease,
			color 0.25s ease,
			box-shadow 0.25s ease;
	}

	:global(.dark) .surface {
		border-color: var(--color-border);
		background: var(--color-surface);
		box-shadow: 
			0 24px 60px rgba(0, 0, 0, 0.35),
			inset 0 1px 0 rgba(255, 255, 255, 0.05),
			0 0 18px oklch(0.68 0.16 var(--hue-40) / 0.045);
	}

	.hero-stage {
		position: relative;
		min-height: clamp(28rem, 70vh, 44rem);
		width: 100%;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: #0d0d0d;
		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.15),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
		transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	:global(.dark) .hero-stage {
		box-shadow:
			0 30px 80px rgba(0, 0, 0, 0.4),
			0 0 100px oklch(0.58 0.2 var(--hue) / 0.08);
	}

	.hero-image {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 42%;
	}

	.hero-scrim {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(
				90deg,
				oklch(0 0 0 / 0.78) 0%,
				oklch(0 0 0 / 0.56) 40%,
				oklch(0 0 0 / 0.18) 70%,
				oklch(0 0 0 / 0.35) 100%
			),
			linear-gradient(
				180deg,
				oklch(0 0 0 / 0.16) 0%,
				oklch(0 0 0 / 0.24) 100%
			);
	}

	.hero-copy {
		position: absolute;
		inset: auto 0 0 0;
		z-index: 1;
		max-width: min(48rem, 72%);
		padding: clamp(1.25rem, 3vw, 2rem);
		color: white;
	}

	.hero-copy .eyebrow,
	.hero-copy .intro,
	.hero-copy .hero-actions,
	.hero-copy .hero-pills,
	.hero-copy h1 {
		color: white;
	}

	.hero-copy .eyebrow {
		margin-bottom: 0.7rem;
	}

	.hero-copy h1 {
		max-width: 10ch;
		font-size: clamp(2.8rem, 5vw, 5.2rem);
		line-height: 0.95;
		text-wrap: balance;
	}

	.hero-copy .intro {
		max-width: 36rem;
		margin-top: 1.2rem;
		color: hsl(220, 15%, 92%);
	}

	.hero-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1.25rem;
	}

	.hero-pills span {
		padding: 0.4rem 0.75rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.1);
		font-size: 0.88rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.9);
	}

	.hero-copy .hero-actions {
		margin-top: 1.5rem;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 20rem;
		gap: 1rem;
	}

	.favorite-preview {
		margin-top: 1rem;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.1rem;
	}

	.section-heading h2 {
		margin: 0;
		font-size: 1.55rem;
		letter-spacing: 0;
	}

	.section-heading > a {
		color: var(--primary);
		font-weight: 800;
		white-space: nowrap;
	}

	.post-list {
		display: grid;
		gap: 0.5rem;
	}

	.post-row {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr) auto;
		gap: 1.25rem;
		align-items: center;
		border: 1px solid var(--color-border);
		background: var(--color-surface-strong);
		border-radius: 8px;
		padding: 1.15rem 1.25rem;
		color: inherit;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.post-row:hover {
		transform: translateX(6px);
		border-color: oklch(0.58 0.2 var(--hue) / 0.4);
		background: var(--color-surface);
		box-shadow: 0 8px 24px var(--color-glow);
	}

	:global(.dark) .post-row:hover {
		border-color: oklch(0.72 0.16 var(--hue) / 0.6);
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
	}

	.post-date {
		color: var(--color-muted);
		font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
		font-size: 0.82rem;
		font-weight: 700;
	}

	.post-row h3 {
		margin: 0 0 0.28rem;
		font-size: 1.05rem;
		letter-spacing: 0;
		font-weight: 700;
	}

	.post-row p {
		margin: 0;
		color: var(--color-muted);
		line-height: 1.55;
		font-size: 0.92rem;
	}

	.post-row > :global(svg) {
		color: var(--primary);
		font-size: 1.6rem;
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.post-row:hover > :global(svg) {
		transform: translateX(4px);
	}

	.side-stack {
		display: grid;
		gap: 1rem;
		align-content: start;
	}

	.link-list,
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.link-list {
		flex-direction: column;
	}

	.link-list a,
	.tag-cloud a {
		border-radius: 8px;
		background: var(--color-surface-strong);
		color: var(--color-text) !important;
		border: 1px solid var(--color-border);
		transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.link-list a {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 2.8rem;
		padding: 0 0.85rem;
	}

	.link-list a:hover,
	.tag-cloud a:hover {
		background: var(--primary);
		border-color: transparent;
		color: #fff !important;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px oklch(0.58 0.2 var(--hue) / 0.3);
	}
	:global(.dark) .link-list a:hover,
	:global(.dark) .tag-cloud a:hover {
		background: var(--primary);
		color: #fff !important;
		box-shadow: 0 6px 20px oklch(0.72 0.16 var(--hue) / 0.25);
	}

	.link-list :global(svg) {
		font-size: 1.05rem;
	}

	.tag-cloud a {
		padding: 0.45rem 0.7rem;
		font-size: 0.9rem;
	}

	.favorite-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.favorite-card {
		display: grid;
		grid-template-rows: auto 1fr;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-surface);
		color: var(--color-text);
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.favorite-card:hover {
		border-color: oklch(0.62 0.14 var(--hue) / 0.36);
		background: var(--color-surface-soft);
		box-shadow: 0 10px 28px var(--color-glow);
		transform: translateY(-2px);
	}

	.favorite-poster {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--color-surface-soft);
	}

	.favorite-poster img,
	.favorite-placeholder {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.favorite-placeholder {
		display: grid;
		place-items: center;
		color: var(--primary);
	}

	.favorite-placeholder :global(svg) {
		font-size: 2.2rem;
	}

	.favorite-poster > span {
		position: absolute;
		top: 0.65rem;
		left: 0.65rem;
		border-radius: 0.45rem;
		background: oklch(0.18 0.02 var(--hue) / 0.72);
		padding: 0.32rem 0.55rem;
		color: white;
		font-size: 0.82rem;
		font-weight: 850;
	}

	.favorite-body {
		display: grid;
		align-content: start;
		gap: 0.55rem;
		padding: 1rem;
	}

	.favorite-body h3 {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 850;
		letter-spacing: 0;
		line-height: 1.35;
	}

	.favorite-body p {
		display: -webkit-box;
		min-height: 2.9rem;
		margin: 0;
		overflow: hidden;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.6;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.favorite-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}

	.favorite-meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.22rem;
		border-radius: 999px;
		background: var(--color-surface-strong);
		padding: 0.24rem 0.55rem;
		color: var(--color-muted);
		font-size: 0.8rem;
		font-weight: 750;
	}

	.favorite-meta :global(svg) {
		color: oklch(0.78 0.16 82);
	}

	.quick-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}

	.quick-grid a {
		display: grid;
		min-height: 10rem;
		align-content: start;
		gap: 0.65rem;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-surface);
		padding: 1rem;
		color: var(--color-text);
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.quick-grid a:hover {
		border-color: oklch(0.62 0.14 var(--hue) / 0.36);
		background: var(--color-surface-soft);
		box-shadow: 0 10px 28px var(--color-glow);
		transform: translateY(-2px);
	}

	.quick-grid :global(svg) {
		color: var(--primary);
		font-size: 1.7rem;
	}

	.quick-grid strong {
		font-size: 1.05rem;
	}

	.quick-grid span {
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	@media (max-width: 980px) {
		.hero,
		.content-grid,
		.favorite-grid,
		.quick-grid {
			grid-template-columns: 1fr;
		}

		.hero-stage {
			min-height: 34rem;
		}
	}

	@media (max-width: 680px) {
		.home-page {
			padding-inline: 0.85rem;
		}

		.hero-stage {
			min-height: 30rem;
		}

		.hero-copy {
			max-width: none;
		}

		.hero-copy h1 {
			max-width: 9ch;
			font-size: clamp(2.25rem, 12vw, 3.6rem);
		}

		.post-row {
			grid-template-columns: 1fr auto;
			gap: 0.75rem;
			padding: 1rem;
		}

		.post-date {
			grid-column: 1 / -1;
		}
	}
</style>
