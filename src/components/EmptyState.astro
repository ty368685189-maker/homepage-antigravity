---
import { Icon } from "astro-icon/components";

interface Props {
	icon: string;
	title: string;
	description: string;
}

const { icon, title, description } = Astro.props;
---

<section class="empty-state" aria-live="polite">
	<div class="empty-icon">
		<Icon name={icon} />
	</div>
	<div>
		<h2>{title}</h2>
		<p>{description}</p>
	</div>
</section>

<style>
	.empty-state {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		border: 1px solid oklch(0.52 0.07 var(--hue) / 0.2);
		border-radius: 8px;
		background: oklch(0.985 0.012 var(--hue) / 0.8);
		padding: 1.15rem;
		color: oklch(0.2 0.025 var(--hue));
	}

	:global(.dark) .empty-state {
		border-color: oklch(0.72 0.075 var(--hue) / 0.2);
		background: oklch(0.16 0.018 var(--hue) / 0.82);
		color: oklch(0.95 0.018 var(--hue));
	}

	.empty-icon {
		display: grid;
		width: 3rem;
		height: 3rem;
		place-items: center;
		border-radius: 8px;
		background: oklch(0.94 0.055 62 / 0.55);
		color: var(--primary);
	}

	.empty-icon :global(svg) {
		font-size: 1.65rem;
	}

	h2,
	p {
		margin: 0;
	}

	h2 {
		font-size: 1.05rem;
		font-weight: 900;
		letter-spacing: 0;
	}

	p {
		margin-top: 0.3rem;
		color: oklch(0.48 0.035 var(--hue));
		line-height: 1.6;
	}

	:global(.dark) p {
		color: oklch(0.78 0.04 var(--hue));
	}

	@media (max-width: 520px) {
		.empty-state {
			grid-template-columns: 1fr;
		}
	}
</style>
