/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 1rem
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: unquote("hsl(var(--hue) 76% 45%)") unquote("hsl(var(--hue) 78% 68%)")
  --primary-gradient: unquote("linear-gradient(135deg, hsl(var(--hue) 78% 52%), hsl(var(--hue-45) 82% 48%))") unquote("linear-gradient(135deg, hsl(var(--hue) 78% 68%), hsl(var(--hue-45) 78% 62%))")
  --page-bg: oklch(0.975 0.006 230) oklch(0.085 0.014 240)
  --card-bg: white(0.25) unquote("oklch(0.16 0.02 240 / 0.40)")
  --navbar-bg: white(0.08) unquote("oklch(0.16 0.02 240 / 0.20)")

  --btn-content: oklch(0.45 0.15 230) oklch(0.78 0.10 230)

  --btn-regular-bg: oklch(0.95 0.02 230) oklch(0.28 0.04 240)
  --btn-regular-bg-hover: oklch(0.90 0.04 230) oklch(0.33 0.05 240)
  --btn-regular-bg-active: oklch(0.85 0.06 230) oklch(0.38 0.05 240)

  --btn-plain-bg-hover: oklch(0.94 0.02 230) oklch(0.26 0.04 240)
  --btn-plain-bg-active: oklch(0.97 0.01 230) oklch(0.23 0.03 240)

  --btn-card-bg-hover: oklch(0.97 0.005 230) oklch(0.26 0.03 240)
  --btn-card-bg-active: oklch(0.90 0.02 230) oklch(0.30 0.04 240)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.20 0.03 230)

  --title-active: oklch(0.50 0.14 230)

  --line-divider: black(0.06) white(0.08)

  --line-color: black(0.08) white(0.10)
  --meta-divider: black(0.15) white(0.18)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: oklch(0.88 0.06 230) oklch(0.35 0.10 240)
  --codeblock-selection: oklch(0.35 0.10 240)
  --codeblock-bg: oklch(0.15 0.02 240) oklch(0.15 0.02 240)
  --codeblock-topbar-bg: oklch(0.25 0.02 240) oklch(0.10 0.02 240)

  --license-block-bg: black(0.03) var(--codeblock-bg)

  --link-underline: oklch(0.90 0.05 230) oklch(0.35 0.10 240)
  --link-hover: oklch(0.93 0.03 230) oklch(0.38 0.10 240)
  --link-active: oklch(0.88 0.06 230) oklch(0.32 0.08 240)

  --float-panel-bg: white(0.75) unquote("oklch(0.18 0.02 240 / 0.80)")

  --scrollbar-bg-light: black(0.35)
  --scrollbar-bg-hover-light: black(0.45)
  --scrollbar-bg-active-light: black(0.55)

  --scrollbar-bg-dark: white(0.35)
  --scrollbar-bg-hover-dark: white(0.45)
  --scrollbar-bg-active-dark: white(0.55)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.65 0.16 180) oklch(0.72 0.16 180)
  --admonitions-color-note: oklch(0.60 0.16 230) oklch(0.70 0.16 230)
  --admonitions-color-important: oklch(0.65 0.16 280) oklch(0.72 0.16 280)
  --admonitions-color-warning: oklch(0.70 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.60 0.20 25) oklch(0.65 0.20 25)

  --toc-badge-bg: oklch(0.88 0.04 230) var(--btn-regular-bg)
  --toc-btn-hover: oklch(0.92 0.015 230) oklch(0.20 0.02 240)
  --toc-btn-active: oklch(0.88 0.015 230) oklch(0.23 0.02 240)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.55 0.16 230) oklch(0.40 0.10 240)

  /* --- Unified Component Surface Tokens --- */
  --color-text: oklch(0.16 0.01 var(--hue)) oklch(0.95 0.005 var(--hue))
  --color-muted: oklch(0.48 0.02 var(--hue)) oklch(0.72 0.02 var(--hue))
  --color-surface: unquote("oklch(0.985 0.006 var(--hue) / 0.94)") unquote("oklch(0.16 0.018 var(--hue) / 0.92)")
  --color-surface-soft: unquote("oklch(0.955 0.014 var(--hue) / 0.72)") unquote("oklch(0.22 0.022 var(--hue) / 0.46)")
  --color-surface-strong: rgba(255, 255, 255, 0.3) rgba(255, 255, 255, 0.04)
  --color-border: rgba(15, 23, 42, 0.08) rgba(255, 255, 255, 0.08)
  --color-glow: rgba(255, 255, 255, 0.15) unquote("oklch(0.68 0.18 var(--hue) / 0.15)")
})
